{% sw_extends '@Storefront/storefront/component/product/card/box-standard.html.twig' %}

{# shopware-block: c614f9aaf7b62764356daaafd06e593d08a062c9dafcfe6788fd131055a21569@v6.6.10.2 #}
{% block component_product_box_price %}
    {{ parent() }}

    {% block component_product_box_price_topi_price_element %}
        {# Option ids are start/center/end; legacy stored values like "justify-content-center" are stripped to their suffix #}
        {% set alignment = config('TopiPaymentIntegrationPlugin.config.productBoxWidgetLocation')|default('center')|replace({'justify-content-': '', 'align-items-': ''}) %}

        {% set legalInfoState = config('TopiPaymentIntegrationPlugin.config.showLegalInfoProductBox') %}
        {# With flex-column (legal info) the horizontal axis is the cross axis, so align-items-* applies; in row direction it's justify-content-* #}
        {% set widgetLocation = (legalInfoState ? 'align-items-' : 'justify-content-') ~ alignment %}
        <div class="topi___price-element mt-2 mb-2 d-flex {{ widgetLocation }}{% if legalInfoState %} flex-column{% endif %}">
           <div class="topi_price-badge">
               {% sw_include '@TopiPaymentIntegrationPlugin/storefront/element/topi/listing-rental-summary-label-widget.html.twig' with {
                   topiProductId: product.id,
               } %}
           </div>
           {% if legalInfoState %}
               <div class="topi__price-legal-info">
                   {{ 'topi.productBox.priceLegalInfo'|trans }}
               </div>
           {% endif %}
        </div>
    {% endblock %}
{% endblock %}
